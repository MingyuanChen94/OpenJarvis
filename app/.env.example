# Optional: absolute base URL for the OpenJarvis backend (`jarvis serve`).
# Leave unset to use same-origin requests (handled by the Vite dev proxy → :8000).
# VITE_API_URL=http://localhost:8000

# Optional: API key if the backend was started with auth enabled.
# VITE_OPENJARVIS_API_KEY=

# Force demo / mock mode even when a backend is reachable (useful for UI work).
# VITE_FORCE_MOCK=1
